meta {
  name: Run Discovery Workflow
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/workflows/discovery/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "role": "Backend Engineer",
    "skills": [
      "TypeScript",
      "Node.js",
      "Express.js",
      "MongoDB",
      "PostgreSQL",
      "Redis",
      "AWS",
      "GCP",
      "Docker",
      "GraphQL",
      "RAG",
      "LLM",
      "LangChain"
    ],
    "experience": "junior",
    "country": "India",
    "locations": ["Hyderabad", "Bengaluru", "Pune", "Chennai"],
    "remoteOnly": false,
    "minExperienceYears": 0,
    "maxExperienceYears": 2,
    "companyTierOrder": ["top", "mid", "other"],
    "highPayFirst": true,
    "minSalaryLpa": 10,
    "maxResults": 40
  }
}

example {
  name: United States Discovery
  
  request: {
    url: {{baseUrl}}/workflows/discovery/run
    method: POST
    mode: json
    headers: {
      Content-Type: application/json
      Accept: application/json
    }
  
    body:json: {
      {
        "role": "Backend Engineer",
        "skills": ["TypeScript", "Node.js", "PostgreSQL", "AWS"],
        "country": "United States",
        "remoteOnly": false,
        "maxResults": 40
      }
    }
  }
}


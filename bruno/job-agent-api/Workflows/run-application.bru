      "skills": ["TypeScript", "Node.js", "Express.js", "MongoDB", "PostgreSQL", "Redis", "Docker", "AWS", "GCP", "GraphQL", "LLM"],
      "experience": "junior"
    },
    "options": {
      "mode": "dry-run",
      "preview": true
    }
  }
}


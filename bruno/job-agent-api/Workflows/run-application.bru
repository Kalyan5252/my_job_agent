}

post {
  url: {{baseUrl}}/workflows/application/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "job": {
      "id": "linkedin-llama-junior-full-stack-developer-bengaluru",
      "source": "linkedin-public",
      "title": "Junior Full Stack Developer",
      "company": "Llama",
      "location": "Bengaluru, Karnataka, India",
      "description": "Junior full stack role requiring TypeScript, Node.js, Express.js, MongoDB, PostgreSQL, and Redis.",
      "requirements": [
        "TypeScript",
        "Node.js",
        "Express.js",
        "MongoDB",
        "PostgreSQL",
        "Redis"
      ],
      "applicationUrl": "https://in.linkedin.com/jobs/view/junior-full-stack-developer-at-llama-4306117443?position=8&pageNum=0&refId=QAM9yUzPZ589stJeBu%2BCFQ%3D%3D&trackingId=CL93a%2BzPE9rekm784U0l7g%3D%3D",
      "score": 88,
      "apply": true,
      "reasoning": "Strong match for junior full stack backend-heavy profile"
    },
    "profile": {

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

OPENAI_API_KEY=
OPENAI_MODEL_JOB_SCORING=gpt-5-mini
OPENAI_MODEL_JOB_DECISION=gpt-5.3
OPENAI_MODEL_FORM_UNDERSTANDING=gpt-5.3

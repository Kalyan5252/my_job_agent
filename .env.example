# =============================
# App Runtime
# =============================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# =============================
# AI Provider Selection
# =============================
# Main LLM provider used for scoring/decision/mapping/status.
# Allowed: openai | openrouter
AI_PROVIDER=openrouter

# Optional scraper-assist model on HTML pages.
AI_SCRAPER_ENABLED=true
# Allowed: openai | openrouter
AI_SCRAPER_PROVIDER=openrouter

# =============================
# OpenAI (used when AI_PROVIDER=openai or AI_SCRAPER_PROVIDER=openai)
# =============================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_JOB_SCORING=gpt-5.4
OPENAI_MODEL_JOB_DECISION=gpt-5.4
OPENAI_MODEL_FORM_UNDERSTANDING=gpt-5.4
OPENAI_MODEL_FIELD_MAPPING=gpt-5.4
OPENAI_MODEL_ANSWER_GENERATION=gpt-5.4
OPENAI_MODEL_EMAIL_PARSING=gpt-5.4
OPENAI_MODEL_STATUS_CLASSIFICATION=gpt-5.4
OPENAI_MODEL_SCRAPER=gpt-5.4-mini

# =============================
# OpenRouter (used when AI_PROVIDER=openrouter or AI_SCRAPER_PROVIDER=openrouter)
# =============================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_JOB_SCORING=google/gemma-4-31b-it
OPENROUTER_MODEL_JOB_DECISION=google/gemma-4-31b-it
OPENROUTER_MODEL_FORM_UNDERSTANDING=google/gemma-4-31b-it
OPENROUTER_MODEL_FIELD_MAPPING=google/gemma-4-31b-it
OPENROUTER_MODEL_ANSWER_GENERATION=google/gemma-4-31b-it
OPENROUTER_MODEL_EMAIL_PARSING=google/gemma-4-31b-it
OPENROUTER_MODEL_STATUS_CLASSIFICATION=google/gemma-4-31b-it
OPENROUTER_MODEL_SCRAPER=google/gemma-4-31b-it
OPENROUTER_RATE_LIMIT_MAX_RETRIES=2
OPENROUTER_RATE_LIMIT_RETRY_DELAY_MS=1500
DISCOVERY_SCORE_BATCH_DELAY_MS=1000
DISCOVERY_SCORE_RATE_LIMIT_BATCH_SIZE=10

# =============================
# Groq (optional; currently disabled)
# =============================
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SCRAPER=openai/gpt-oss-20b
GROQ_SCRAPER_ENABLED=false

# =============================
# Discovery / Scraper
# =============================
SCRAPER_ALLOW_SYNTHETIC_FALLBACK=false
INDIAN_JOB_SOURCES_ENABLED=true
LINKEDIN_SCRAPER_ENABLED=true

# Adzuna is currently disabled in code, keep keys optional.
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# JSearch via RapidAPI
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# =============================
# Auth Sessions (application agent)
# =============================
LINKEDIN_AUTH_ENABLED=true
LINKEDIN_STORAGE_STATE_PATH=.auth/linkedin-storage-state.json
GOOGLE_AUTH_ENABLED=true
GOOGLE_STORAGE_STATE_PATH=.auth/google-storage-state.json
GOOGLE_AUTH_DOMAIN_ALLOWLIST=

# =============================
# Candidate Profile / Resume Paths
# =============================
RESUME_FILE_PATH=data/resume/Kalyan Show (1).pdf
RESUME_TEXT_PATH=data/profile/resume.txt
CANDIDATE_PROFILE_PATH=data/profile/candidateProfile.json
MANUAL_PROFILE_PATH=data/profile/manualProfile.json

SECONDARY_EMAIL=kalyan.s.apple@gmail.com
SECONDARY_RESUME_FILE_PATH=data/resume/Kalyan Show (2).pdf
SECONDARY_RESUME_TEXT_PATH=data/profile/resume.secondary.txt
SECONDARY_CANDIDATE_PROFILE_PATH=data/profile/candidateProfile.secondary.json

# =============================
# Databases
# =============================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=job_agent

# Use full URI (example for Neon):
# postgresql://user:password@host/db?sslmode=require
POSTGRES_URL=postgresql://user:password@host/db?sslmode=require
POSTGRES_SSL_MODE=prefer
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# =============================
# Redis / Queue
# =============================
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================
# Email Tracking
# =============================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_imap_app_password
IMAP_TLS=true

# =============================
# Default Discovery Profile
# =============================
DEFAULT_JOB_ROLE=Backend Engineer
DEFAULT_JOB_SKILLS=TypeScript,Node.js,Express.js,MongoDB,PostgreSQL,Redis,AWS,GCP,Docker,GraphQL,RAG,LLM,LangChain,React,Next.js
DEFAULT_JOB_EXPERIENCE=junior

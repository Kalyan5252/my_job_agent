NODE_ENV=development
PORT=3000
LOG_LEVEL=info

AI_PROVIDER=gemini
  GEMINI_API_KEY=your_key

  AI_SCRAPER_ENABLED=true
  AI_SCRAPER_PROVIDER=gemini
  GEMINI_MODEL_SCRAPER=gemini-1.5-flash

  To switch back:

  AI_PROVIDER=openai
  OPENAI_API_KEY=your_key

  AI_SCRAPER_ENABLED=true
  AI_SCRAPER_PROVIDER=openai
  OPENAI_MODEL_SCRAPER=gpt-5.4-mini

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_JOB_SCORING=gpt-5.4
OPENAI_MODEL_JOB_DECISION=gpt-5.4
OPENAI_MODEL_FORM_UNDERSTANDING=gpt-5.4
OPENAI_MODEL_FIELD_MAPPING=gpt-5.4
OPENAI_MODEL_ANSWER_GENERATION=gpt-5.4
OPENAI_MODEL_EMAIL_PARSING=gpt-5.4
OPENAI_MODEL_STATUS_CLASSIFICATION=gpt-5.4

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_JOB_SCORING=gemini-3.1-pro-preview
GEMINI_MODEL_JOB_DECISION=gemini-3.1-pro-preview


GEMINI_MODEL_FORM_UNDERSTANDING=gemini-3-flash-live
GEMINI_MODEL_FIELD_MAPPING=gemini-3-flash-live
GEMINI_MODEL_ANSWER_GENERATION=gemini-3-flash-live

GEMINI_MODEL_EMAIL_PARSING=gemini-3.1-flash-lite
GEMINI_MODEL_STATUS_CLASSIFICATION=gemini-3.1-flash-lite
GEMINI_RATE_LIMIT_MAX_RETRIES=2
GEMINI_RATE_LIMIT_RETRY_DELAY_MS=1500
DISCOVERY_SCORE_BATCH_DELAY_MS=1000
DISCOVERY_SCORE_RATE_LIMIT_BATCH_SIZE=10

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SCRAPER=openai/gpt-oss-20b
GROQ_SCRAPER_ENABLED=false
SCRAPER_ALLOW_SYNTHETIC_FALLBACK=false
INDIAN_JOB_SOURCES_ENABLED=true
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com
LINKEDIN_SCRAPER_ENABLED=true

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=job_agent

POSTGRES_URL=your_postgres_url_here
POSTGRES_SSL_MODE=prefer
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_TLS=true

DEFAULT_JOB_ROLE=Backend Engineer
DEFAULT_JOB_SKILLS=TypeScript,Node.js,Express.js,MongoDB,PostgreSQL,Redis,AWS,GCP,Docker,GraphQL,RAG,LLM,LangChain,React,Next.js
DEFAULT_JOB_EXPERIENCE=junior

{
  "name": "my-job-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered multi-agent job application system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/queues/worker.ts",
    "dev:cron": "tsx watch scripts/cronJobs.ts",
    "auth:linkedin": "tsx scripts/saveLinkedinSession.ts",
    "auth:google": "tsx scripts/saveGoogleSession.ts",
    "auth:google:refresh": "tsx scripts/saveGoogleSession.ts",
    "auth:google:capture": "tsx scripts/captureGoogleSessionFromChrome.ts",
    "resume:import": "python3 scripts/import_resume_profile.py --pdf \"data/resume/Kalyan Show (1).pdf\"",
    "resume:import:secondary": "python3 scripts/import_resume_profile.py --pdf \"data/resume/Kalyan Show (2).pdf\" --out-text \"data/profile/resume.secondary.txt\" --out-profile \"data/profile/candidateProfile.secondary.json\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/queues/worker.js",
    "start:cron": "node dist/scripts/cronJobs.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bullmq": "^5.12.7",
    "dotenv": "^16.4.5",
    "esbuild": "0.19.12",
    "fastify": "^5.0.0",
    "imap": "^0.8.19",
    "ioredis": "^5.4.1",
    "mailparser": "^3.7.1",
    "mongodb": "^6.8.0",
    "node-cron": "^3.0.3",
    "openai": "^4.56.0",
    "pg": "^8.12.0",
    "playwright": "1.59.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/imap": "^0.8.42",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
